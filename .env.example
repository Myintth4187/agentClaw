# ============================================================
# 环境变量配置
# ============================================================

# ── OpenClaw 镜像与版本 (建议固化版本号) ─────────────────────────────
# OpenClaw 镜像名称（默认 openclaw:latest）
OPENCLAW_IMAGE=openclaw:latest
# OpenClaw 版本（用于构建 openclaw-shared 镜像）
OPENCLAW_VERSION=2026.3.8

# ── 本地模型或服务配置 (vLLM/其他兼容OpenAI接口的服务) ───────────────────
# 注意：Docker容器内访问宿主机使用 host.docker.internal 代替 localhost
# HOSTED_VLLM_API_KEY=sk-ecJ5VIKzqMGbXWhtNOpIRfKTcTTI5ZKd
# HOSTED_VLLM_API_BASE=http://host.docker.internal:23456/v1

# ── 统一 LLM 端点配置（OpenAI 兼容格式）───────────────────────────────
# 用于：OpenRouter、Together、Fireworks、自定义代理等 OpenAI 兼容端点
# 配置此项后，所有模型请求都会走这个端点（优先级最高）
#
# 使用方式：
# 1. OpenRouter: DEFAULT_MODEL=openrouter/stepfun/step-3.5-flash:free
# 2. Together:   DEFAULT_MODEL=together/meta-llama/Meta-Llama-3.1-70B
# 3. Fireworks:  DEFAULT_MODEL=fireworks/accounts/fireworks/models/llama-v3p1-70b
# 4. 通用兼容:   DEFAULT_MODEL=stepfun/step-3.5-flash:free  (默认会使用 openai/ 前缀)
#
LLM_API_BASE=
LLM_API_KEY=

# ── 默认模型 ─────────────────────────────────────────────────────
DEFAULT_MODEL=openrouter/stepfun/step-3.5-flash:free

# ── 自定义 Claude 协议端点 ───────────────────────────────────────
# 用于接入原生 Claude 协议的自定义端点
# PLATFORM_CLAUDE_API_KEY=
# PLATFORM_CLAUDE_API_BASE=http://host.docker.internal:23456


# ── 安全配置 ─────────────────────────────────────────────────────
JWT_SECRET=dev-secret-key-change-in-production

# ── 其他LLM服务商（可选）─────────────────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DASHSCOPE_API_KEY=
# DEEPSEEK_API_KEY=
